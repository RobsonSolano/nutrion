# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Google OAuth (Web Client ID usado no signInWithIdToken)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxx.apps.googleusercontent.com

# Sentry (observabilidade) — DSN é público (não é secret).
# Pra source maps em build de produção rode `npx @sentry/wizard@latest -i reactNative`
# e ele cria sentry.properties com auth token (esse SIM é secret e fica no gitignore).
EXPO_PUBLIC_SENTRY_DSN=https://YOUR_KEY@oXXXX.ingest.us.sentry.io/XXXX

# Service role do Supabase — APENAS pra rodar `npm run seed:user` localmente.
# NUNCA expor no app (não tem prefixo EXPO_PUBLIC_, fica fora do bundle).
# Pega em: Supabase Dashboard → Settings → API → "service_role" → Reveal.
SUPABASE_SERVICE_ROLE_KEY=eyJ...
